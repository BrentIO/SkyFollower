{
    "latitude": 38.8969137,
    "longitude": -77.0357096,
    "adsb": {
        "uri": "my.adsb.server.lan",
        "port": 30002,
        "type": "raw"
    },
    "mongoDb": {
        "uri": "localhost",
        "port": 27017,
        "database": "SkyFollower",
        "collection": "flights"
    },
    "registration": {
        "enabled": false,
        "uri": "http://localhost:8480/registration?icao_hex=$ICAO_HEX$",
        "x-api-key": "some_secret_key"
    },
    "operators": {
        "enabled": false,
        "uri": "http://localhost:8480/operator?airline_designator=$CALLSIGN$",
        "x-api-key": "some_secret_key"
    },
    "mqtt": {
        "enabled": false,
        "uri": "my.mqtt.server.lan",
        "port": 1883,
        "username": "my_username",
        "password": "my_clear_text_password",
        "topic": "SkyFollower/"
    },
    "files": {
        "areas": "./areas.geojson",
        "rules": "./rules.json"
    },
    "home_assistant":{
        "enabled" : false,
        "discovery_prefix" : "homeassistant"
    }
}