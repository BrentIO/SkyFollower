@startuml
!include ../../images/common.iuml

title SkyFollower — Message Pipeline

skinparam defaultTextAlignment center
skinparam rectangle {
    BorderColor black
    BackgroundColor white
}
skinparam package {
    BorderColor black
    BackgroundColor white
    FontStyle bold
}

package "Host A — Raspberry Pi" as HostA {
    rectangle "RTL-SDR 1090\n→ readsb :30002" as Sdr1090
    rectangle "RTL-SDR 978\n→ readsb :30978" as Sdr978
    rectangle "Receiver\n--\nTags: raw, icao_hex, received_at, source\nRoutes: adsb-{icao_hex_int % PROCESSOR_COUNT}" as Receiver
    rectangle "queue.db (SQLite WAL)\ndrains on reconnect" as ReceiverFallback #FFE5CC
}

package "Host B — Central Server" as HostB {
    rectangle "RabbitMQ" as Rmq
}

package "Host C — Processor Host" as HostC {
    rectangle "Processor\n--\nPROCESSOR_ID unique-checked via Redis NX key on startup\nSQLite in-memory active store\nRedis enrichment lookups (Host B)\nRules engine → MQTT notifications" as Processor
}

package "Host D — Archive Host" as HostD {
    rectangle "Archive Processor" as Archive
    rectangle "archive.db (SQLite WAL)" as ArchiveFallback #FFE5CC
    rectangle "AWS S3\n(.json.gz)" as S3
    rectangle "Parquet index\n(design TBD)" as Parquet #E8E8E8
}

Sdr1090 --> Receiver
Sdr978 --> Receiver

Receiver --> Rmq : RabbitMQ available
Receiver --> ReceiverFallback : RabbitMQ offline
ReceiverFallback ..> Rmq : drains on reconnect

Rmq --> Processor

Processor --> Archive : RabbitMQ available\n(archive queue)
Processor --> ArchiveFallback : RabbitMQ offline
ArchiveFallback ..> Archive : drains on reconnect

Archive --> S3
Archive --> Parquet

@enduml
