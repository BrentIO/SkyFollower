@startuml
!include ../../images/common.iuml

title SkyFollower — Message Pipeline

skinparam defaultTextAlignment center
skinparam rectangle {
    BorderColor black
    BackgroundColor white
}
skinparam package {
    BorderColor black
    BackgroundColor white
    FontStyle bold
}

package "Host A — Receiver" as HostA {
    rectangle "RTL-SDR 1090\n→ readsb :30002" as Sdr1090
    rectangle "RTL-SDR 978\n→ readsb :30978" as Sdr978
    rectangle "Receiver\n--\nTags: raw, icao_hex, received_at, source\nRoutes: adsb-{icao_hex_int % PROCESSOR_COUNT}" as Receiver
    database "queue.db\n(SQLite WAL)" as ReceiverFallback #FFE5CC
}

package "Host C — Processor" as HostC {
    rectangle "Processor\n--\nPROCESSOR_ID unique-checked via Redis NX key on startup\nSQLite in-memory active store\nRedis enrichment lookups (Host B)\nRules engine → MQTT notifications" as ProcessorC
}

note right of HostC : One to many processors supported

package "Host B — Central Server" as HostB {
    rectangle "RabbitMQ" as Rmq
    database "Redis" as Redis
}

package "Host D — Archive Host" as HostD {
    rectangle "Archive Processor" as Archive
    database "archive.db\n(SQLite WAL)" as ArchiveFallback #FFE5CC
    rectangle "AWS S3\n(.json.gz)" as S3
    rectangle "Parquet index\n(design TBD)" as Parquet #E8E8E8
}

Sdr1090 --> Receiver
Sdr978 --> Receiver

Receiver -right-> Rmq : RabbitMQ available
Receiver -> ReceiverFallback : RabbitMQ offline
ReceiverFallback ..> Rmq : drains on reconnect

ProcessorC --> Rmq : consumes adsb-{PROCESSOR_ID}

ProcessorC -down--> Redis : enrichment lookups

ProcessorC --> Archive : RabbitMQ available\n(archive queue)
ProcessorC --> ArchiveFallback : RabbitMQ offline
ArchiveFallback ..> Archive : drains on reconnect

Archive --> S3
Archive --> Parquet

HostA -[hidden]down-> HostC
HostC -[hidden]down-> HostB
HostB -[hidden]right-> HostD

@enduml
