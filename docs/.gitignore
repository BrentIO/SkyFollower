.vitepress/dist

# Generated by scripts/generate-pages.mjs (see #434, #448) — source of
# truth is the READMEs these are copied and link-rewritten from, not these
# files.
components/receiver.md
components/processor.md
components/shared.md
components/archive-processor.md
data-runners/

# Generated by scripts/generate-diagrams.mjs from each component's own
# .puml file(s) (see #463) — copied here from receiver/receiver.svg etc. so
# each component's generated page can embed them. Source of truth is the
# .puml. A component may have more than one diagram, so this is a wildcard
# rather than one entry per file.
components/*.svg

# Generated by scripts/bundle-specs.mjs (see #433) — the web component
# bundle is copied from node_modules and the spec is copied from
# specs/asyncapi.yaml, neither of which belongs committed here.
public/asyncapi/

# Generated by scripts/generate-diagrams.mjs (see #435) — each PlantUML
# diagram's rendered SVG is mirrored here (at its literal relative path)
